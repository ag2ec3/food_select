# Copy to `.env.local` and set values from your Supabase project (Settings → API).
# Use either legacy anon JWT or new publishable key (not secret / not service_role).
# If both are set, Publishable is used first (avoids a stale anon hiding a good publishable key).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
